<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#141009"/>
            <stroke android:width="1dp" android:color="#2D2016"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item android:width="3dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="#55D97D2E"/>
            <corners android:topLeftRadius="14dp" android:bottomLeftRadius="14dp"/>
        </shape>
    </item>
</layer-list>

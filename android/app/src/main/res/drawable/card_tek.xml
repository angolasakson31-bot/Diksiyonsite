<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0f1520"/>
            <stroke android:width="1dp" android:color="#1e2d40"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item android:width="3dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="#66c8a84b"/>
            <corners android:topLeftRadius="12dp" android:bottomLeftRadius="12dp"/>
        </shape>
    </item>
</layer-list>

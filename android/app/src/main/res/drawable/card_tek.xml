<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F1520"/>
            <stroke android:width="1dp" android:color="#1E2D40"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item android:width="3dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="#55C8A84B"/>
            <corners android:topLeftRadius="14dp" android:bottomLeftRadius="14dp"/>
        </shape>
    </item>
</layer-list>

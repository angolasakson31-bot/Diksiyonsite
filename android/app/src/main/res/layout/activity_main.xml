<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Splash / Loading -->
    <LinearLayout
        android:id="@+id/splash_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="28dp">

            <View android:id="@+id/bar1"
                android:layout_width="14dp" android:layout_height="34dp"
                android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
            <View android:id="@+id/bar2"
                android:layout_width="14dp" android:layout_height="54dp"
                android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
            <View android:id="@+id/bar3"
                android:layout_width="14dp" android:layout_height="74dp"
                android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
            <View android:id="@+id/bar4"
                android:layout_width="14dp" android:layout_height="54dp"
                android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
            <View android:id="@+id/bar5"
                android:layout_width="14dp" android:layout_height="34dp"
                android:background="@drawable/bar_gold"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DiksiPro"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="#e8c96b"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SES EĞİTİMİ"
            android:textSize="11sp"
            android:textColor="#4a6a88"
            android:letterSpacing="0.35"/>

    </LinearLayout>

    <!-- Offline -->
    <LinearLayout
        android:id="@+id/offline_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="24dp">
            <View android:layout_width="8dp" android:layout_height="14dp"
                android:background="@drawable/bar_gold" android:alpha="0.2" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="26dp"
                android:background="@drawable/bar_gold" android:alpha="0.2" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="38dp"
                android:background="@drawable/bar_gold" android:alpha="0.2" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="48dp"
                android:background="@drawable/bar_gold" android:alpha="0.2"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bağlantı Yok"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#c8a84b"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="İnternet bağlantınızı kontrol edin"
            android:textSize="14sp"
            android:textColor="#3d5568"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/retry_button"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:text="Tekrar Dene"
            android:textColor="#080b10"
            android:backgroundTint="#c8a84b"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Splash / Loading -->
    <RelativeLayout
        android:id="@+id/splash_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Centered: bars + name + tagline -->
        <LinearLayout
            android:id="@+id/splash_center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_centerInParent="true">

            <!-- 7 organic voice-waveform bars -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="90dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="28dp">

                <View android:id="@+id/bar1"
                    android:layout_width="12dp" android:layout_height="22dp"
                    android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
                <View android:id="@+id/bar2"
                    android:layout_width="12dp" android:layout_height="51dp"
                    android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
                <View android:id="@+id/bar3"
                    android:layout_width="12dp" android:layout_height="36dp"
                    android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
                <View android:id="@+id/bar4"
                    android:layout_width="12dp" android:layout_height="90dp"
                    android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
                <View android:id="@+id/bar5"
                    android:layout_width="12dp" android:layout_height="41dp"
                    android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
                <View android:id="@+id/bar6"
                    android:layout_width="12dp" android:layout_height="66dp"
                    android:background="@drawable/bar_gold" android:layout_marginEnd="7dp"/>
                <View android:id="@+id/bar7"
                    android:layout_width="12dp" android:layout_height="23dp"
                    android:background="@drawable/bar_gold"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DiksiPro"
                android:textSize="46sp"
                android:textStyle="bold"
                android:textColor="#e8c96b"
                android:layout_marginBottom="7dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SES &amp; DİKSİYON"
                android:textSize="11sp"
                android:textColor="#3a5268"
                android:letterSpacing="0.38"/>

        </LinearLayout>

        <!-- Bottom pulsing dots -->
        <LinearLayout
            android:id="@+id/dots_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="52dp">

            <View android:id="@+id/dot1"
                android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/dot_gold" android:alpha="0.15"
                android:layout_marginEnd="9dp"/>
            <View android:id="@+id/dot2"
                android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/dot_gold" android:alpha="0.15"
                android:layout_marginEnd="9dp"/>
            <View android:id="@+id/dot3"
                android:layout_width="7dp" android:layout_height="7dp"
                android:background="@drawable/dot_gold" android:alpha="0.15"/>

        </LinearLayout>

    </RelativeLayout>

    <!-- Offline: tap anywhere to retry, auto-retries on reconnect -->
    <LinearLayout
        android:id="@+id/offline_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Dimmed signal indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="28dp">
            <View android:layout_width="8dp" android:layout_height="10dp"
                android:background="@drawable/bar_gold" android:alpha="0.12"
                android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="20dp"
                android:background="@drawable/bar_gold" android:alpha="0.12"
                android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="30dp"
                android:background="@drawable/bar_gold" android:alpha="0.12"
                android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="40dp"
                android:background="@drawable/bar_gold" android:alpha="0.12"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bağlantı Yok"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#604a20"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bağlantı kurulunca otomatik devam eder"
            android:textSize="13sp"
            android:textColor="#243040"
            android:gravity="center"/>

    </LinearLayout>

</FrameLayout>
